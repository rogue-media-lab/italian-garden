<div class="flex items-center justify-between mb-8">
  <h2 class="text-2xl font-bold text-gray-900">Meal Deals</h2>
  <%= link_to "New Meal Deal", new_admin_meal_deal_path, class: "bg-gray-900 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-800" %>
</div>

<div class="space-y-3">
  <% @deals.each do |deal| %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-center gap-4 flex-1">
        <% deal_photo = FoodPhotos.for(deal.main_item.name) %>
        <% if deal_photo %>
          <%= image_tag deal_photo, class: "w-16 h-16 rounded-lg object-cover flex-shrink-0" %>
        <% else %>
          <div class="w-16 h-16 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
            <span class="text-gray-300 text-2xl">🍽️</span>
          </div>
        <% end %>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-semibold text-gray-900"><%= deal.name %></span>
              <span class="text-sm font-medium text-green-700"><%= deal.formatted_price %></span>
              <% if deal.featured? %>
                <span class="text-xs bg-amber-100 text-amber-800 px-2 py-0.5 rounded">Featured</span>
              <% end %>
              <% unless deal.active? %>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">Inactive</span>
              <% end %>
            </div>
            <p class="text-sm text-gray-500">
              <%= deal.main_item.name %> + <%= deal.default_side.name %> + <%= deal.default_drink.name %>
            </p>
            <% if deal.description.present? %>
              <p class="text-xs text-gray-400 mt-1"><%= deal.description %></p>
            <% end %>
          </div>
        </div>
        <div class="flex gap-2 flex-shrink-0">
          <%= link_to "Edit", edit_admin_meal_deal_path(deal), class: "text-sm text-blue-600 hover:underline" %>
          <%= button_to "Delete", admin_meal_deal_path(deal), method: :delete, data: { turbo_confirm: "Delete this meal deal?" }, class: "text-sm text-red-600 hover:underline inline bg-transparent border-0 cursor-pointer p-0" %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @deals.empty? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 text-center">
      <p class="text-gray-400">No meal deals yet. Create one to feature combos on the homepage.</p>
    </div>
  <% end %>
</div>
