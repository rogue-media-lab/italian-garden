<%= turbo_stream_from "admin_orders" %>

<div class="flex items-center justify-between mb-8">
  <h2 class="text-2xl font-bold text-gray-900">Orders</h2>
  <div class="flex gap-2">
    <%= link_to "All", admin_orders_path, class: "px-3 py-1.5 rounded text-sm #{params[:status].blank? ? 'bg-gray-900 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
    <%= link_to "Pending", admin_orders_path(status: "pending"), class: "px-3 py-1.5 rounded text-sm #{params[:status] == 'pending' ? 'bg-amber-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
    <%= link_to "Ready", admin_orders_path(status: "ready"), class: "px-3 py-1.5 rounded text-sm #{params[:status] == 'ready' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
  </div>
</div>

<div id="orders_list" class="space-y-3">
  <% @orders.each do |order| %>
    <%= render "admin/orders/order", order: order %>
  <% end %>

  <% if @orders.empty? %>
    <div id="empty_orders" class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 text-center">
      <p class="text-gray-400">No orders yet.</p>
    </div>
  <% end %>
</div>
