<div id="order_<%= order.id %>" class="bg-white rounded-lg shadow-sm border border-gray-200 p-5">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-3">
        <span class="font-semibold text-gray-900">Order #<%= order.id %></span>
        <span class="text-xs px-2 py-0.5 rounded <%= order.status_color %>"><%= order.status.capitalize %></span>
        <span class="text-xs text-gray-400"><%= order.created_at.strftime('%b %d, %l:%M %p') %></span>
      </div>

      <div class="grid grid-cols-3 gap-4 text-sm mb-3">
        <div>
          <p class="text-xs text-gray-400">Customer</p>
          <p class="font-medium text-gray-900"><%= order.customer_name %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400">Phone</p>
          <p class="font-medium text-gray-900"><%= order.phone %></p>
        </div>
        <div>
          <p class="text-xs text-gray-400">Pickup</p>
          <p class="font-medium text-gray-900"><%= order.pickup_time&.strftime('%l:%M %p')&.strip %></p>
        </div>
      </div>

      <div class="bg-gray-50 rounded p-3">
        <% order.order_items.each do |item| %>
          <div class="flex justify-between text-sm py-0.5">
            <span class="text-gray-600"><%= item.quantity %>× <%= item.menu_item.name %></span>
            <span class="text-gray-900"><%= item.formatted_subtotal %></span>
          </div>
        <% end %>
        <div class="flex justify-between text-sm font-bold pt-2 mt-2 border-t border-gray-200">
          <span>Total</span>
          <span><%= order.formatted_total %></span>
        </div>
      </div>
    </div>

    <div class="flex gap-2 flex-shrink-0">
      <% if order.status == "pending" %>
        <%= button_to "Ready", admin_order_path(order, order: { status: "ready" }), method: :patch, class: "text-sm bg-green-600 text-white px-3 py-1.5 rounded hover:bg-green-700 cursor-pointer" %>
      <% elsif order.status == "ready" %>
        <%= button_to "Complete", admin_order_path(order, order: { status: "completed" }), method: :patch, class: "text-sm bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 cursor-pointer" %>
      <% end %>
      <%= button_to "Delete", admin_order_path(order), method: :delete, data: { turbo_confirm: "Delete this order?" }, class: "text-sm text-red-600 hover:underline cursor-pointer bg-transparent border-0 p-0" %>
    </div>
  </div>
</div>
