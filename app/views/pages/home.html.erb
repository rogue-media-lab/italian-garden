<!-- Hero -->
<section class="bg-[#8B1A1A] flex flex-col items-center justify-center px-6 md:px-12 py-20 md:py-28 text-center relative overflow-hidden">
  <div class="w-16 h-0.5 bg-[#C9A96E] mb-7"></div>
  <p class="text-sm font-medium text-[#C9A96E] uppercase tracking-[0.15em] mb-4">York, South Carolina — Family Owned</p>
  <h1 class="text-4xl md:text-6xl font-bold text-[#FAF3E8] max-w-3xl leading-tight tracking-tight"><%= @hero_heading %></h1>
  <p class="text-base md:text-lg text-[#FAF3E8]/80 max-w-xl mt-5 leading-relaxed"><%= @hero_subheading %></p>
  <div class="flex flex-col sm:flex-row gap-4 mt-10">
    <a href="/menu" class="text-sm font-semibold text-[#8B1A1A] bg-[#C9A96E] px-9 py-3.5 rounded">View Our Menu</a>
    <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-sm font-semibold text-[#FAF3E8] border border-[#FAF3E8]/40 px-9 py-3.5 rounded">Call to Order</a>
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-[#C9A96E] to-transparent"></div>
</section>

<!-- Signature Favorites -->
<% if @featured_deals.any? || @featured_items.any? %>
<section class="px-6 md:px-12 py-16 md:py-20 bg-[#FAF3E8]">
  <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] text-center mb-2">From Our Kitchen</p>
  <h2 class="text-3xl md:text-4xl font-bold text-[#3D2B1F] text-center mb-12 tracking-tight">Signature Favorites</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <%# Show meal deals first, then individual featured items to fill remaining slots %>
    <% @featured_deals.each do |deal| %>
      <% deal_photo = FoodPhotos.for(deal.main_item.name) %>
      <div class="bg-white rounded-lg overflow-hidden shadow-sm">
        <div class="h-48 bg-gradient-to-br from-[#D4A373] to-[#8B1A1A] flex items-center justify-center relative">
          <% if deal_photo %>
            <%= image_tag deal_photo, class: "w-full h-full object-cover" %>
          <% else %>
            <span class="text-5xl opacity-30">🍽️</span>
          <% end %>
          <span class="absolute top-3 right-3 bg-[#C9A96E] text-[#3D2B1F] text-xs font-bold px-2 py-1 rounded">COMBO</span>
        </div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-2">
            <h3 class="text-lg font-bold text-[#3D2B1F]"><%= deal.name %></h3>
            <span class="text-lg font-bold text-[#8B1A1A]"><%= deal.formatted_price %></span>
          </div>
          <p class="text-sm text-[#6B6055] mb-4 leading-relaxed"><%= deal.main_item.name %> + <%= deal.default_side.name %> + Drink</p>
          <%= button_to "Add Meal to Cart", cart_add_meal_path(deal_id: deal.id), method: :post, class: "w-full text-sm font-semibold text-[#FAF3E8] bg-[#8B1A1A] px-4 py-2.5 rounded cursor-pointer hover:bg-[#6d1515]" %>
        </div>
      </div>
    <% end %>
    <%# Fill remaining slots with individual featured items %>
    <% remaining = 3 - @featured_deals.size %>
    <% @featured_items.first(remaining).each do |item| %>
      <% item_photo = FoodPhotos.for(item.name) %>
      <div class="bg-white rounded-lg overflow-hidden shadow-sm">
        <div class="h-48 bg-gradient-to-br from-[#D4A373] to-[#8B1A1A] flex items-center justify-center">
          <% if item_photo %>
            <%= image_tag item_photo, class: "w-full h-full object-cover" %>
          <% else %>
            <span class="text-5xl opacity-30">🍽️</span>
          <% end %>
        </div>
        <div class="p-6">
          <h3 class="text-lg font-bold text-[#3D2B1F]"><%= item.name %></h3>
          <p class="text-sm text-[#6B6055] mt-2 leading-relaxed"><%= item.description %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<!-- Our Story -->
<% if @about_heading.present? %>
<section class="px-6 md:px-12 py-16 md:py-20 bg-[#F5E6CC]">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-12 md:gap-16">
    <div class="flex-1 max-w-lg">
      <p class="text-xs font-medium text-[#8B1A1A] uppercase tracking-[0.1em] mb-3">Our Story</p>
      <h2 class="text-3xl md:text-4xl font-bold text-[#3D2B1F] leading-tight tracking-tight mb-5"><%= @about_heading %></h2>
      <p class="text-base text-[#5A4A3F] leading-relaxed"><%= @about_body %></p>
    </div>
    <div class="flex-1 max-w-sm h-72 rounded-lg overflow-hidden">
      <%= image_tag @storefront_image, alt: "Italian Garden Restaurant storefront", class: "w-full h-full object-cover rounded-lg" %>
    </div>
  </div>
</section>
<% end %>

<!-- Menu Preview -->
<section class="px-6 md:px-12 py-16 md:py-20 bg-[#3D2B1F]">
  <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] text-center mb-2">What We Serve</p>
  <h2 class="text-3xl md:text-4xl font-bold text-[#FAF3E8] text-center mb-4 tracking-tight">Our Menu</h2>
  <p class="text-base text-[#FAF3E8]/60 text-center max-w-lg mx-auto mb-12">From hearty Italian classics to American favorites — generous portions at honest prices.</p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">
    <% @categories.limit(3).each do |cat| %>
      <div>
        <h3 class="text-lg font-bold text-[#C9A96E] pb-3 border-b border-[#C9A96E]/30 mb-5"><%= cat.name %></h3>
        <div class="space-y-3.5">
          <% cat.menu_items.active.limit(7).each do |item| %>
            <div class="flex justify-between items-baseline">
              <span class="text-sm font-medium text-[#FAF3E8]"><%= item.name %></span>
              <span class="text-sm text-[#FAF3E8]/50"><%= item.formatted_price %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <a href="/menu" class="text-sm font-medium text-[#C9A96E] uppercase tracking-wider border-b border-[#C9A96E] pb-0.5 hover:text-[#e0c08a]">View Full Menu →</a>
  </div>
</section>

<!-- Reviews -->
<section class="px-6 md:px-12 py-16 md:py-20 bg-[#FAF3E8]">
  <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] text-center mb-2">What People Say</p>
  <h2 class="text-3xl md:text-4xl font-bold text-[#3D2B1F] text-center mb-4 tracking-tight">Our Regulars Keep Coming Back</h2>

  <% if @google_reviews %>
    <div class="flex items-center justify-center gap-3 mb-10">
      <span class="text-3xl font-bold text-[#3D2B1F]"><%= @google_reviews[:rating] %></span>
      <div>
        <div class="flex gap-0.5">
          <% @google_reviews[:rating].to_i.times do %><span class="text-[#C9A96E] text-lg">★</span><% end %>
          <% (5 - @google_reviews[:rating].to_i).times do %><span class="text-[#C9A96E]/30 text-lg">★</span><% end %>
        </div>
        <p class="text-xs text-[#5A4A3F]">Google Reviews · <%= @google_reviews[:total] %> reviews</p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-7 max-w-6xl mx-auto">
    <% reviews = @google_reviews&.dig(:reviews) || @testimonials.map { |t| { author: t.customer_name, rating: t.stars, text: t.quote } } %>
    <% reviews.first(3).each do |r| %>
      <div class="bg-white rounded-lg p-8 border-l-[3px] border-[#C9A96E]">
        <div class="flex gap-1 mb-4">
          <% r[:rating].to_i.times do %><span class="text-[#C9A96E]">★</span><% end %>
        </div>
        <p class="text-sm text-[#3D2B1F] leading-relaxed italic mb-5">"<%= r[:text] %>"</p>
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-[#8B1A1A]">— <%= r[:author] %></p>
          <% if r[:time] %><p class="text-xs text-[#5A4A3F]/50"><%= r[:time] %></p><% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-10">
    <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] mb-4">Leave a Review</p>
    <div class="flex items-center justify-center gap-6">
      <!-- Google -->
      <a href="https://www.google.com/maps/place/Italian+Garden+Restaurant/@34.9875107,-81.2274933,17z/data=!4m8!3m7!1s0x8856f38afc7c1885:0x1c7a0b6c7cc288e7!8m2!3d34.9875107!4d-81.2274933!9m1!1b1!16s%2Fg%2F1tfh_96q?entry=ttu&g_ep=EgoyMDI2MDQyOS4wIKXMDSoASAFQAw%3D%3D" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-google text-xl" style="color: #4285F4;"></i>
        </div>
        <span class="text-xs text-[#3D2B1F]/60 group-hover:text-[#3D2B1F]">Google</span>
      </a>
      <!-- Yelp -->
      <a href="https://www.yelp.com/biz/italian-garden-restaurant-york" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-yelp text-xl" style="color: #D32323;"></i>
        </div>
        <span class="text-xs text-[#3D2B1F]/60 group-hover:text-[#3D2B1F]">Yelp</span>
      </a>
      <!-- TripAdvisor -->
      <a href="https://www.tripadvisor.com/Restaurant_Review-g54509-d3620460-Reviews-Italian_Garden_Restaurant-York_South_Carolina.html" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" fill="#34E0A1"/>
            <circle cx="8.5" cy="11" r="3" fill="white"/>
            <circle cx="15.5" cy="11" r="3" fill="white"/>
            <circle cx="8.5" cy="11" r="1.5" fill="#34E0A1"/>
            <circle cx="15.5" cy="11" r="1.5" fill="#34E0A1"/>
            <circle cx="12" cy="5.5" r="2" fill="white"/>
            <circle cx="12" cy="5.5" r="1" fill="#34E0A1"/>
          </svg>
        </div>
        <span class="text-xs text-[#3D2B1F]/60 group-hover:text-[#3D2B1F]">TripAdvisor</span>
      </a>
      <!-- Facebook -->
      <a href="https://www.facebook.com/p/Italian-Garden-Restaurant-100070887769336/" target="_blank" class="flex flex-col items-center gap-2 group">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <i class="fa-brands fa-facebook text-xl" style="color: #1877F2;"></i>
        </div>
        <span class="text-xs text-[#3D2B1F]/60 group-hover:text-[#3D2B1F]">Facebook</span>
      </a>
    </div>
  </div>
</section>

<!-- Contact & Map -->
<section class="px-6 md:px-12 py-16 md:py-20 bg-[#8B1A1A]">
  <p class="text-xs font-medium text-[#C9A96E] uppercase tracking-[0.15em] text-center mb-2">Come See Us</p>
  <h2 class="text-3xl md:text-4xl font-bold text-[#FAF3E8] text-center mb-12 tracking-tight">Visit Italian Garden</h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-5xl mx-auto">
    <!-- Hours -->
    <div>
      <h3 class="text-xs font-semibold text-[#C9A96E] uppercase tracking-[0.1em] mb-5">Hours</h3>
      <div class="space-y-3">
        <% @hours.each do |h| %>
          <div class="flex justify-between">
            <span class="text-sm text-[#FAF3E8]/80"><%= h.day_name %></span>
            <span class="text-sm font-medium text-[#FAF3E8]"><%= h.formatted_hours %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Contact -->
    <div>
      <h3 class="text-xs font-semibold text-[#C9A96E] uppercase tracking-[0.1em] mb-5">Contact</h3>
      <p class="text-sm text-[#FAF3E8]/80 mb-1"><%= @address %></p>
      <a href="tel:<%= @phone&.gsub(/[^0-9]/, '') %>" class="text-lg font-semibold text-[#C9A96E] block mt-3"><%= @phone %></a>
      <p class="text-sm text-[#FAF3E8]/60 mt-1"><%= @email %></p>
    </div>

    <!-- Map -->
    <div>
      <h3 class="text-xs font-semibold text-[#C9A96E] uppercase tracking-[0.1em] mb-5">Find Us</h3>
      <div class="aspect-square rounded-lg overflow-hidden">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3265.123456789!2d-81.2274933!3d34.9875107!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8856f38afc7c1885%3A0x1c7a0b6c7cc288e7!2sItalian%20Garden%20Restaurant!5e0!3m2!1sen!2sus!4v1" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>
